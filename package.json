{
  "name": "@processengine/mappings",
  "version": "2.2.0",
  "description": "Declarative JSON mappings runtime for ProcessEngine",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema/mapping-definition.v1.schema.json": "./schema/mapping-definition.v1.schema.json",
    "./package.json": "./package.json"
  },
  "bin": {
    "mappings": "./bin/mappings.js"
  },
  "files": [
    "dist/",
    "schema/",
    "bin/",
    "README.md",
    "README.ru.md",
    "SPEC.md",
    "SPEC_RU.md",
    "COMPATIBILITY.md",
    "MIGRATION.md",
    "CHANGELOG.md",
    "RELEASE_NOTES_2.0.0.md",
    "RELEASE_NOTES_2.0.1.md",
    "RELEASE_NOTES_2.1.0.md",
    "RELEASE_NOTES_2.2.0.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "pretest": "npm run build",
    "test": "node --test test/*.test.js",
    "test:pack": "node ./scripts/pack-install-test.mjs",
    "bench": "node benchmarks/run.mjs"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "keywords": [
    "json",
    "mapping",
    "normalization",
    "transformation",
    "declarative",
    "dsl",
    "processengine"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/processengine/mappings.git"
  },
  "homepage": "https://github.com/processengine/mappings#readme",
  "bugs": {
    "url": "https://github.com/processengine/mappings/issues"
  }
}
