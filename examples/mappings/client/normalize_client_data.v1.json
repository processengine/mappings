{
  "mappingId": "profile.normalize_input.v1",
  "sources": {
    "raw": "object"
  },
  "output": {
    "profile.phoneDigits": { "removeNonDigits": "sources.raw.phone" },
    "profile.email": { "lowercase": "sources.raw.email" },
    "profile.displayName": { "normalizeSpaces": "sources.raw.fullName" },
    "profile.category": {
      "transform": {
        "from": "sources.raw.category",
        "steps": [
          { "trim": true },
          { "uppercase": true },
          {
            "mapValue": {
              "map": {
                "A": "ALPHA",
                "ALPHA": "ALPHA",
                "B": "BETA",
                "BETA": "BETA"
              },
              "fallback": null
            }
          }
        ]
      }
    },
    "profile.country": {
      "mapValue": {
        "from": "sources.raw.countryCode",
        "map": {
          "DE": "DE",
          "DEU": "DE",
          "FRA": "FR",
          "FR": "FR",
          "ESP": "ES"
        },
        "fallback": "passthrough"
      }
    },
    "profile.hasDocument": { "exists": "sources.raw.documentId" }
  }
}
