{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://processengine.io/schemas/mappings/mapping-definition.v1.schema.json",
  "title": "MappingDefinition",
  "description": "Декларативное описание маппинга @processengine/mappings v1",
  "type": "object",
  "required": ["mappingId", "sources", "output"],
  "additionalProperties": false,
  "properties": {
    "mappingId": {
      "type": "string",
      "minLength": 1,
      "description": "Уникальный идентификатор сценария маппинга"
    },
    "sources": {
      "type": "object",
      "description": "Объявление источников данных. Ключ — имя источника, значение — тип.",
      "additionalProperties": {
        "type": "string",
        "enum": ["object"]
      }
    },
    "output": {
      "type": "object",
      "description": "Правила построения результата. Ключ — целевой путь, значение — оператор.",
      "additionalProperties": {
        "$ref": "#/definitions/OutputRule"
      }
    }
  },
  "definitions": {
    "JsonSafeLiteral": {
      "description": "JSON-безопасное значение: string, конечное число, boolean или null",
      "oneOf": [
        { "type": "string" },
        { "type": "number", "not": { "enum": [null] } },
        { "type": "boolean" },
        { "type": "null" }
      ]
    },
    "MapValueFallback": {
      "description": "Поведение при ненайденном ключе: JSON-safe literal или passthrough",
      "oneOf": [
        { "$ref": "#/definitions/JsonSafeLiteral" },
        { "type": "string", "enum": ["passthrough"] }
      ]
    },
    "MapDict": {
      "type": "object",
      "description": "Словарь канонизации. Ключи — строки, значения — JSON-safe literals.",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/definitions/JsonSafeLiteral"
      }
    },
    "CoalesceCandidate": {
      "type": "object",
      "description": "Кандидат coalesce: path-объект или literal-объект",
      "oneOf": [
        {
          "required": ["path"],
          "additionalProperties": false,
          "properties": {
            "path": { "type": "string", "minLength": 1 }
          }
        },
        {
          "required": ["literal"],
          "additionalProperties": false,
          "properties": {
            "literal": { "$ref": "#/definitions/JsonSafeLiteral" }
          }
        }
      ]
    },
    "TransformStep": {
      "type": "object",
      "description": "Один шаг внутри transform.steps",
      "oneOf": [
        {
          "required": ["trim"],
          "additionalProperties": false,
          "properties": { "trim": { "type": "boolean", "enum": [true] } }
        },
        {
          "required": ["lowercase"],
          "additionalProperties": false,
          "properties": { "lowercase": { "type": "boolean", "enum": [true] } }
        },
        {
          "required": ["uppercase"],
          "additionalProperties": false,
          "properties": { "uppercase": { "type": "boolean", "enum": [true] } }
        },
        {
          "required": ["normalizeSpaces"],
          "additionalProperties": false,
          "properties": { "normalizeSpaces": { "type": "boolean", "enum": [true] } }
        },
        {
          "required": ["removeNonDigits"],
          "additionalProperties": false,
          "properties": { "removeNonDigits": { "type": "boolean", "enum": [true] } }
        },
        {
          "required": ["mapValue"],
          "additionalProperties": false,
          "properties": {
            "mapValue": {
              "type": "object",
              "description": "mapValue в шаговой форме — без поля from",
              "required": ["map"],
              "additionalProperties": false,
              "properties": {
                "map": { "$ref": "#/definitions/MapDict" },
                "fallback": { "$ref": "#/definitions/MapValueFallback" }
              }
            }
          }
        }
      ]
    },
    "OutputRule": {
      "type": "object",
      "description": "Ровно один оператор на поле output",
      "oneOf": [
        {
          "required": ["from"],
          "additionalProperties": false,
          "properties": {
            "from": { "type": "string", "minLength": 1 }
          }
        },
        {
          "required": ["literal"],
          "additionalProperties": false,
          "properties": {
            "literal": { "$ref": "#/definitions/JsonSafeLiteral" }
          }
        },
        {
          "required": ["exists"],
          "additionalProperties": false,
          "properties": {
            "exists": { "type": "string", "minLength": 1 }
          }
        },
        {
          "required": ["equals"],
          "additionalProperties": false,
          "properties": {
            "equals": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": [
                { "type": "string", "minLength": 1 },
                { "$ref": "#/definitions/JsonSafeLiteral" }
              ]
            }
          }
        },
        {
          "required": ["coalesce"],
          "additionalProperties": false,
          "properties": {
            "coalesce": {
              "type": "array",
              "minItems": 1,
              "maxItems": 4,
              "items": { "$ref": "#/definitions/CoalesceCandidate" }
            }
          }
        },
        {
          "required": ["trim"],
          "additionalProperties": false,
          "properties": { "trim": { "type": "string", "minLength": 1 } }
        },
        {
          "required": ["lowercase"],
          "additionalProperties": false,
          "properties": { "lowercase": { "type": "string", "minLength": 1 } }
        },
        {
          "required": ["uppercase"],
          "additionalProperties": false,
          "properties": { "uppercase": { "type": "string", "minLength": 1 } }
        },
        {
          "required": ["normalizeSpaces"],
          "additionalProperties": false,
          "properties": { "normalizeSpaces": { "type": "string", "minLength": 1 } }
        },
        {
          "required": ["removeNonDigits"],
          "additionalProperties": false,
          "properties": { "removeNonDigits": { "type": "string", "minLength": 1 } }
        },
        {
          "required": ["mapValue"],
          "additionalProperties": false,
          "properties": {
            "mapValue": {
              "type": "object",
              "description": "mapValue в корневой форме — обязателен from",
              "required": ["from", "map"],
              "additionalProperties": false,
              "properties": {
                "from": { "type": "string", "minLength": 1 },
                "map": { "$ref": "#/definitions/MapDict" },
                "fallback": { "$ref": "#/definitions/MapValueFallback" }
              }
            }
          }
        },
        {
          "required": ["transform"],
          "additionalProperties": false,
          "properties": {
            "transform": {
              "type": "object",
              "required": ["from", "steps"],
              "additionalProperties": false,
              "properties": {
                "from": { "type": "string", "minLength": 1 },
                "steps": {
                  "type": "array",
                  "minItems": 2,
                  "maxItems": 8,
                  "items": { "$ref": "#/definitions/TransformStep" }
                }
              }
            }
          }
        }
      ]
    }
  }
}
