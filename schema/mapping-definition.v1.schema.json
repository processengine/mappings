{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://processengine.io/schemas/mappings/mapping-definition.v1.schema.json",
  "title": "MappingDefinition",
  "description": "Declarative mapping definition for @processengine/mappings source artifacts",
  "type": "object",
  "required": ["mappingId", "sources", "output"],
  "additionalProperties": false,
  "properties": {
    "mappingId": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "object",
      "additionalProperties": { "type": "string", "enum": ["object"] }
    },
    "output": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/OutputRule" }
    }
  },
  "definitions": {
    "JsonSafeLiteral": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" }
      ]
    },
    "MapValueFallback": {
      "oneOf": [
        { "$ref": "#/definitions/JsonSafeLiteral" },
        { "type": "string", "enum": ["passthrough"] }
      ]
    },
    "MapDict": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/definitions/JsonSafeLiteral" }
    },
    "CoalesceCandidate": {
      "oneOf": [
        {
          "type": "object",
          "required": ["path"],
          "additionalProperties": false,
          "properties": { "path": { "type": "string", "minLength": 1 } }
        },
        {
          "type": "object",
          "required": ["literal"],
          "additionalProperties": false,
          "properties": { "literal": { "$ref": "#/definitions/JsonSafeLiteral" } }
        }
      ]
    },
    "TransformStep": {
      "oneOf": [
        { "type": "object", "required": ["trim"], "additionalProperties": false, "properties": { "trim": { "type": "boolean", "enum": [true] } } },
        { "type": "object", "required": ["lowercase"], "additionalProperties": false, "properties": { "lowercase": { "type": "boolean", "enum": [true] } } },
        { "type": "object", "required": ["uppercase"], "additionalProperties": false, "properties": { "uppercase": { "type": "boolean", "enum": [true] } } },
        { "type": "object", "required": ["normalizeSpaces"], "additionalProperties": false, "properties": { "normalizeSpaces": { "type": "boolean", "enum": [true] } } },
        { "type": "object", "required": ["removeNonDigits"], "additionalProperties": false, "properties": { "removeNonDigits": { "type": "boolean", "enum": [true] } } },
        {
          "type": "object",
          "required": ["mapValue"],
          "additionalProperties": false,
          "properties": {
            "mapValue": {
              "type": "object",
              "required": ["map"],
              "additionalProperties": false,
              "properties": {
                "map": { "$ref": "#/definitions/MapDict" },
                "fallback": { "$ref": "#/definitions/MapValueFallback" }
              }
            }
          }
        }
      ]
    },
    "ArrayCondition": {
      "type": "object",
      "required": ["field"],
      "properties": {
        "field": { "type": "string", "minLength": 1 },
        "equals": { "$ref": "#/definitions/JsonSafeLiteral" },
        "in": {
          "type": "array",
          "items": { "$ref": "#/definitions/JsonSafeLiteral" }
        },
        "startsWith": { "type": "string" }
      },
      "additionalProperties": false,
      "anyOf": [
        { "required": ["equals"] },
        { "required": ["in"] },
        { "required": ["startsWith"] }
      ]
    },
    "AggregateBase": {
      "type": "object",
      "required": ["from"],
      "properties": {
        "from": { "type": "string", "pattern": "^sources\\..+\\[\\*\\]$" },
        "where": { "$ref": "#/definitions/ArrayCondition" },
        "match": { "$ref": "#/definitions/ArrayCondition" },
        "value": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "OutputRule": {
      "oneOf": [
        { "type": "object", "required": ["from"], "additionalProperties": false, "properties": { "from": { "type": "string", "minLength": 1 } } },
        { "type": "object", "required": ["literal"], "additionalProperties": false, "properties": { "literal": { "$ref": "#/definitions/JsonSafeLiteral" } } },
        { "type": "object", "required": ["exists"], "additionalProperties": false, "properties": { "exists": { "type": "string", "minLength": 1 } } },
        { "type": "object", "required": ["equals"], "additionalProperties": false, "properties": { "equals": { "type": "array", "minItems": 2, "maxItems": 2, "items": [{ "type": "string", "minLength": 1 }, { "$ref": "#/definitions/JsonSafeLiteral" }] } } },
        { "type": "object", "required": ["coalesce"], "additionalProperties": false, "properties": { "coalesce": { "type": "array", "minItems": 1, "maxItems": 4, "items": { "$ref": "#/definitions/CoalesceCandidate" } } } },
        { "type": "object", "required": ["trim"], "additionalProperties": false, "properties": { "trim": { "type": "string", "minLength": 1 } } },
        { "type": "object", "required": ["lowercase"], "additionalProperties": false, "properties": { "lowercase": { "type": "string", "minLength": 1 } } },
        { "type": "object", "required": ["uppercase"], "additionalProperties": false, "properties": { "uppercase": { "type": "string", "minLength": 1 } } },
        { "type": "object", "required": ["normalizeSpaces"], "additionalProperties": false, "properties": { "normalizeSpaces": { "type": "string", "minLength": 1 } } },
        { "type": "object", "required": ["removeNonDigits"], "additionalProperties": false, "properties": { "removeNonDigits": { "type": "string", "minLength": 1 } } },
        { "type": "object", "required": ["mapValue"], "additionalProperties": false, "properties": { "mapValue": { "type": "object", "required": ["from", "map"], "additionalProperties": false, "properties": { "from": { "type": "string", "minLength": 1 }, "map": { "$ref": "#/definitions/MapDict" }, "fallback": { "$ref": "#/definitions/MapValueFallback" } } } } },
        { "type": "object", "required": ["transform"], "additionalProperties": false, "properties": { "transform": { "type": "object", "required": ["from", "steps"], "additionalProperties": false, "properties": { "from": { "type": "string", "minLength": 1 }, "steps": { "type": "array", "minItems": 2, "maxItems": 8, "items": { "$ref": "#/definitions/TransformStep" } } } } } },
        { "type": "object", "required": ["collect"], "additionalProperties": false, "properties": { "collect": { "allOf": [{ "$ref": "#/definitions/AggregateBase" }, { "required": ["value"] }] } } },
        { "type": "object", "required": ["count"], "additionalProperties": false, "properties": { "count": { "$ref": "#/definitions/AggregateBase" } } },
        { "type": "object", "required": ["collectObject"], "additionalProperties": false, "properties": { "collectObject": { "allOf": [{ "$ref": "#/definitions/AggregateBase" }, { "required": ["fields"] }] } } },
        { "type": "object", "required": ["existsAny"], "additionalProperties": false, "properties": { "existsAny": { "$ref": "#/definitions/AggregateBase" } } },
        { "type": "object", "required": ["existsAll"], "additionalProperties": false, "properties": { "existsAll": { "allOf": [{ "$ref": "#/definitions/AggregateBase" }, { "required": ["match"] }] } } },
        { "type": "object", "required": ["pickFirst"], "additionalProperties": false, "properties": { "pickFirst": { "$ref": "#/definitions/AggregateBase" } } }
      ]
    }
  }
}
